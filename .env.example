# Clerk Publishable Key (starts with pk_test_ or pk_live_)
# Used to initialize Clerk authentication on the client (Expo).
# Where to find: Clerk Dashboard -> API Keys -> Publishable key.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# NestJS API base URL
EXPO_PUBLIC_API_URL=http://localhost:8000

# Local UI work only — skip login / role checks (__DEV__ required).
# Set to true to open /dashboard without signing in. Never enable in production.
EXPO_PUBLIC_DEV_BYPASS_AUTH=false

# Optional: email of an existing DB user to load/save personal info & documents while auth bypass is on.
EXPO_PUBLIC_DEV_PROFILE_EMAIL=